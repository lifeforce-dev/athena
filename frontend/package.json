    "driver.js": "^1.4.0",
    "intl-messageformat": "^11.1.2",
    "pinia": "^3.0.4",
    "vue": "^3.4.38",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.4",
    "openapi-typescript": "^7.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.1.0"
  }
}
