# Athena Configuration
# Copy to .env and fill in values. All prefixed with ATHENA_.

# Path to JSON config file (file-based projection fallback)
ATHENA_CONFIG_PATH=data.json

# Comma-separated CORS origins (local dev only; production uses proxy)
ATHENA_CORS_ORIGINS=http://localhost:5173

# PostgreSQL connection string (Render provides this)
# ATHENA_DATABASE_URL=postgresql://user:password@host:5432/athena

# JWT signing secret (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
# ATHENA_JWT_SECRET=

# Discord OAuth2 (https://discord.com/developers/applications)
# ATHENA_DISCORD_CLIENT_ID=
# ATHENA_DISCORD_CLIENT_SECRET=
# ATHENA_DISCORD_REDIRECT_URI=http://localhost:5173/api/auth/callback

# Frontend URL (post-login redirect target)
ATHENA_FRONTEND_URL=http://localhost:5173
